{"id":"cnt_8880d46e","title":"做一个赛博朋克风格的个人名片","description":"哈哈","type":"game","code":"<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover\">\n    <title>赛博朋克名片</title>\n    <style>\n        /* 基础重置与变量 - 已修改为红色主题 */\n        :root {\n            --primary-neon: #ff003c;\n            --secondary-neon: #ff6600;\n            --dark-bg: #140a0a;\n            --grid-line: rgba(255, 0, 60, 0.1);\n            --text-glow: 0 0 8px var(--primary-neon);\n            --orange-glow: 0 0 8px var(--secondary-neon);\n            --spacing-unit: 1rem;\n            --card-width: 90vw;\n            --max-card-width: 350px;\n        }\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        html {\n            font-size: 16px;\n            font-family: 'Courier New', 'SF Mono', Monaco, monospace;\n        }\n        body {\n            background-color: var(--dark-bg);\n            color: #ffe0e0;\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            padding: var(--spacing-unit);\n            overflow-x: hidden;\n            /* 网格背景 */\n            background-image:\n                linear-gradient(var(--grid-line) 1px, transparent 1px),\n                linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);\n            background-size: 30px 30px;\n        }\n        /* 减少运动偏好 */\n        @media (prefers-reduced-motion: no-preference) {\n            .scan-line {\n                animation: scan 3s linear infinite;\n            }\n            .flicker {\n                animation: flicker 5s infinite alternate;\n            }\n            .pulse {\n                animation: pulse 2s infinite ease-in-out;\n            }\n        }\n\n        /* 动画定义 */\n        @keyframes scan {\n            0% { transform: translateY(-100%); }\n            100% { transform: translateY(844px); }\n        }\n        @keyframes flicker {\n            0%, 19%, 23%, 29%, 33%, 67%, 71%, 89%, 93%, 100% { opacity: 0.9; }\n            20%, 24%, 30%, 68%, 90%, 94% { opacity: 0.2; }\n        }\n        @keyframes pulse {\n            0%, 100% { opacity: 1; }\n            50% { opacity: 0.7; }\n        }\n\n        /* 主卡片容器 */\n        .cyber-card {\n            width: min(var(--card-width), var(--max-card-width));\n            background-color: rgba(30, 15, 15, 0.85);\n            border: 1px solid var(--primary-neon);\n            border-radius: 4px;\n            padding: calc(var(--spacing-unit) * 1.5);\n            position: relative;\n            overflow: hidden;\n            box-shadow:\n                0 0 20px rgba(255, 0, 60, 0.3),\n                inset 0 0 15px rgba(255, 0, 60, 0.05);\n            margin-bottom: calc(var(--spacing-unit) * 2);\n            z-index: 1;\n        }\n        /* 装饰性扫描线 */\n        .scan-line {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 3px;\n            background: linear-gradient(90deg, transparent, var(--primary-neon), transparent);\n            z-index: 0;\n            opacity: 0.6;\n        }\n        /* 装饰性角标 */\n        .corner {\n            position: absolute;\n            width: 20px;\n            height: 20px;\n        }\n        .corner-tl {\n            top: 8px;\n            left: 8px;\n            border-top: 2px solid var(--secondary-neon);\n            border-left: 2px solid var(--secondary-neon);\n        }\n        .corner-br {\n            bottom: 8px;\n            right: 8px;\n            border-bottom: 2px solid var(--secondary-neon);\n            border-right: 2px solid var(--secondary-neon);\n        }\n\n        /* 头像区域 */\n        .avatar-section {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            margin-bottom: calc(var(--spacing-unit) * 1.5);\n        }\n        .avatar-container {\n            width: 100px;\n            height: 100px;\n            border-radius: 50%;\n            border: 2px solid var(--primary-neon);\n            padding: 4px;\n            margin-bottom: var(--spacing-unit);\n            background-color: rgba(0, 0, 0, 0.5);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            box-shadow: 0 0 15px var(--primary-neon);\n        }\n        .avatar {\n            width: 100%;\n            height: 100%;\n            border-radius: 50%;\n            object-fit: cover;\n            display: block;\n        }\n        /* 默认头像 - SVG占位 */\n        .default-avatar {\n            width: 100%;\n            height: 100%;\n            fill: none;\n            stroke: var(--primary-neon);\n            stroke-width: 2;\n        }\n        .name-title {\n            text-align: center;\n        }\n        .name {\n            font-size: 1.8rem;\n            font-weight: bold;\n            color: #fff;\n            text-shadow: var(--text-glow);\n            letter-spacing: 1px;\n            margin-bottom: 0.25rem;\n        }\n        .title {\n            font-size: 1rem;\n            color: var(--secondary-neon);\n            text-shadow: var(--orange-glow);\n            letter-spacing: 2px;\n        }\n\n        /* 信息区域 */\n        .info-section {\n            border-top: 1px dashed rgba(255, 0, 60, 0.4);\n            border-bottom: 1px dashed rgba(255, 0, 60, 0.4);\n            padding: var(--spacing-unit) 0;\n            margin-bottom: var(--spacing-unit);\n        }\n        .info-item {\n            display: flex;\n            align-items: center;\n            margin-bottom: 0.75rem;\n            min-height: 44px; /* 最小触控区域 */\n        }\n        .info-item:last-child {\n            margin-bottom: 0;\n        }\n        .icon {\n            flex-shrink: 0;\n            width: 20px;\n            height: 20px;\n            margin-right: 0.75rem;\n            fill: var(--primary-neon);\n            filter: drop-shadow(var(--text-glow));\n        }\n        .info-text {\n            font-size: 0.95rem;\n            line-height: 1.4;\n            word-break: break-word;\n        }\n        .info-text a {\n            color: var(--secondary-neon);\n            text-decoration: none;\n            border-bottom: 1px dotted var(--secondary-neon);\n        }\n        .info-text a:active, .info-text a:hover {\n            text-shadow: var(--orange-glow);\n        }\n\n        /* 技能标签 */\n        .skills-section {\n            margin-bottom: var(--spacing-unit);\n        }\n        .section-label {\n            font-size: 0.9rem;\n            color: var(--primary-neon);\n            margin-bottom: 0.5rem;\n            display: flex;\n            align-items: center;\n        }\n        .section-label::before {\n            content: '>';\n            margin-right: 0.5rem;\n            color: var(--secondary-neon);\n        }\n        .skill-tags {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 0.5rem;\n        }\n        .tag {\n            background-color: rgba(255, 102, 0, 0.1);\n            color: #ffd9cc;\n            border: 1px solid var(--secondary-neon);\n            padding: 0.5rem 0.8rem;\n            font-size: 0.85rem;\n            border-radius: 2px;\n            text-shadow: 0 0 4px var(--secondary-neon);\n        }\n\n        /* 行动按钮 */\n        .action-section {\n            display: flex;\n            justify-content: space-between;\n            gap: 0.75rem;\n        }\n        .cyber-btn {\n            flex: 1;\n            min-height: 44px; /* 最小触控区域 */\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            background-color: transparent;\n            border: 1px solid;\n            font-family: inherit;\n            font-size: 0.9rem;\n            font-weight: bold;\n            letter-spacing: 1px;\n            cursor: pointer;\n            text-decoration: none;\n            border-radius: 2px;\n            transition: all 0.2s ease;\n        }\n        .cyber-btn:active {\n            transform: scale(0.98);\n        }\n        .btn-contact {\n            border-color: var(--primary-neon);\n            color: var(--primary-neon);\n            text-shadow: var(--text-glow);\n        }\n        .btn-contact:active, .btn-contact:hover {\n            background-color: rgba(255, 0, 60, 0.1);\n        }\n        .btn-portfolio {\n            border-color: var(--secondary-neon);\n            color: var(--secondary-neon);\n            text-shadow: var(--orange-glow);\n        }\n        .btn-portfolio:active, .btn-portfolio:hover {\n            background-color: rgba(255, 102, 0, 0.1);\n        }\n\n        /* 底部签名 */\n        .footer {\n            margin-top: calc(var(--spacing-unit) * 1.5);\n            font-size: 0.75rem;\n            color: rgba(255, 224, 224, 0.6);\n            text-align: center;\n            max-width: var(--max-card-width);\n        }\n        .footer .neon-text {\n            color: var(--primary-neon);\n            text-shadow: 0 0 5px var(--primary-neon);\n        }\n\n        /* 桌面端适配 */\n        @media (min-width: 768px) {\n            :root {\n                --card-width: 50vw;\n                --max-card-width: 400px;\n                --spacing-unit: 1.25rem;\n            }\n            html {\n                font-size: 18px;\n            }\n            .cyber-card {\n                padding: calc(var(--spacing-unit) * 2);\n            }\n            .avatar-container {\n                width: 120px;\n                height: 120px;\n            }\n            .name {\n                font-size: 2.2rem;\n            }\n            .info-text {\n                font-size: 1rem;\n            }\n        }\n\n        /* 强制竖屏布局 */\n        @media (orientation: landscape) and (max-height: 600px) {\n            body {\n                padding-top: 2rem;\n                padding-bottom: 2rem;\n                justify-content: flex-start;\n            }\n            .cyber-card {\n                margin-bottom: 1rem;\n            }\n            .action-section {\n                flex-direction: column;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"scan-line\"></div>\n    <div class=\"cyber-card flicker\">\n        <div class=\"corner corner-tl\"></div>\n        <div class=\"corner corner-br\"></div>\n\n        <div class=\"avatar-section\">\n            <div class=\"avatar-container pulse\">\n                <!-- 默认SVG头像，用户可替换为<img> -->\n                <svg class=\"default-avatar\" viewBox=\"0 0 100 100\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <circle cx=\"50\" cy=\"40\" r=\"20\" />\n                    <path d=\"M30 85 Q50 65 70 85\" />\n                </svg>\n                <!-- 用户可用真实图片替换上方svg\n                <img src=\"avatar.jpg\" alt=\"头像\" class=\"avatar\">\n                -->\n            </div>\n            <div class=\"name-title\">\n                <h1 class=\"name\">NEO_CORP_01</h1>\n                <p class=\"title\">全栈神经接口工程师</p>\n            </div>\n        </div>\n\n        <div class=\"info-section\">\n            <div class=\"info-item\">\n                <svg class=\"icon\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z\"/>\n                </svg>\n                <div class=\"info-text\">neo.corp01@cybermail.io</div>\n            </div>\n            <div class=\"info-item\">\n                <svg class=\"icon\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z\"/>\n                </svg>\n                <div class=\"info-text\">+86 138 0013 8000</div>\n            </div>\n            <div class=\"info-item\">\n                <svg class=\"icon\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z\"/>\n                </svg>\n                <div class=\"info-text\">夜之城， 新港区， 第7层</div>\n            </div>\n            <div class=\"info-item\">\n                <svg class=\"icon\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z\"/>\n                </svg>\n                <div class=\"info-text\">\n                    <a href=\"https://neural-net.cyber\" target=\"_blank\">neural-net.cyber</a>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"skills-section\">\n            <div class=\"section-label\">核心协议 / 技能栈</div>\n            <div class=\"skill-tags\">\n                <span class=\"tag\">神经接口编程</span>\n                <span class=\"tag\">AI 驯化</span>\n                <span class=\"tag\">数据挖掘</span>\n                <span class=\"tag\">加密破解</span>\n                <span class=\"tag\">硬件骇入</span>\n            </div>\n        </div>\n\n        <div class=\"action-section\">\n            <button class=\"cyber-btn btn-contact\" onclick=\"alert('信号发送中...\\\\n频率: 2077.0 MHz\\\\n等待回应。')\">发送连接请求</button>\n            <a href=\"#portfolio\" class=\"cyber-btn btn-portfolio\">查看数据档案</a>\n        </div>\n    </div>\n\n    <div class=\"footer\">\n        <p>状态: <span class=\"neon-text pulse\">在线</span> | 最后更新: 2077-10-23</p>\n        <p>© 2077 NEO_CORP. 所有神经数据均受加密保护。</p>\n        <p style=\"margin-top:0.5rem; font-size:0.7rem;\">* 本名片为纯HTML/CSS实现，无外部依赖。</p>\n    </div>\n\n    <script>\n        // 简单的内联交互脚本\n        document.addEventListener('DOMContentLoaded', function() {\n            const buttons = document.querySelectorAll('.cyber-btn');\n            buttons.forEach(btn => {\n                btn.addEventListener('touchstart', function() {\n                    this.style.opacity = '0.8';\n                });\n                btn.addEventListener('touchend', function() {\n                    this.style.opacity = '1';\n                });\n            });\n\n            // 模拟“查看数据档案”按钮的占位行为\n            const portfolioBtn = document.querySelector('.btn-portfolio');\n            if(portfolioBtn) {\n                portfolioBtn.addEventListener('click', function(e) {\n                    e.preventDefault();\n                    alert('正在访问加密数据仓库...\\n(此为示例，实际项目需链接至真实地址)');\n                });\n            }\n        });\n    </script>\n</body>\n</html>","coverUrl":"","coverEmoji":"🎂","coverGradient":"linear-gradient(135deg, #fa709a 0%, #fee140 100%)","tags":[],"authorId":"u_b6cdb943","status":"published","playCount":0,"likeCount":1,"favoriteCount":0,"commentCount":2,"remixCount":0,"createdAt":"2026-04-13T16:13:18.071Z","publishedAt":"2026-04-13T16:13:18.076Z"}