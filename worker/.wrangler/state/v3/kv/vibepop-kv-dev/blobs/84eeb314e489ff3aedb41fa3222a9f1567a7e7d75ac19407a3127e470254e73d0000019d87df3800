{"id":"cnt_fce81c1a","title":"做一个雷霆战机游戏","description":"","type":"game","code":"<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover\">\n    <title>雷霆战机</title>\n    <style>\n        /* 基础重置 */\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            -webkit-tap-highlight-color: transparent;\n            font-family: 'Arial Rounded MT Bold', 'Arial', sans-serif;\n        }\n\n        html, body {\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            background-color: #0a0e29;\n            color: #fff;\n            touch-action: none;\n        }\n\n        /* 游戏容器 */\n        #gameContainer {\n            width: 100vw;\n            height: 100vh;\n            max-width: 100vw;\n            position: relative;\n            display: flex;\n            flex-direction: column;\n            justify-content: flex-start;\n            align-items: center;\n            overflow: hidden;\n        }\n\n        /* 游戏画布 */\n        #gameCanvas {\n            display: block;\n            width: 100%;\n            height: 100%;\n            background: radial-gradient(circle at center, #1a237e 0%, #0a0e29 70%);\n            image-rendering: pixelated;\n            image-rendering: crisp-edges;\n        }\n\n        /* 游戏UI覆盖层 */\n        #gameUI {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            display: flex;\n            flex-direction: column;\n            padding: 1rem;\n            z-index: 10;\n        }\n\n        /* 顶部状态栏 */\n        .status-bar {\n            width: 100%;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            pointer-events: auto;\n            margin-bottom: 1rem;\n        }\n\n        .score, .lives, .level {\n            background-color: rgba(0, 20, 60, 0.7);\n            padding: 0.5rem 1rem;\n            border-radius: 2rem;\n            font-size: 1.1rem;\n            font-weight: bold;\n            border: 2px solid #4fc3f7;\n            box-shadow: 0 0 10px rgba(79, 195, 247, 0.5);\n            min-height: 44px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        /* 控制区域 */\n        .controls {\n            position: absolute;\n            bottom: 2rem;\n            width: 100%;\n            display: flex;\n            justify-content: space-between;\n            padding: 0 1.5rem;\n            pointer-events: auto;\n        }\n\n        .control-btn {\n            width: 70px;\n            height: 70px;\n            min-width: 70px;\n            min-height: 70px;\n            border-radius: 50%;\n            background-color: rgba(33, 150, 243, 0.8);\n            border: 3px solid #e3f2fd;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 1.8rem;\n            color: white;\n            box-shadow: 0 4px 15px rgba(33, 150, 243, 0.6);\n            cursor: pointer;\n            pointer-events: auto;\n            user-select: none;\n            touch-action: manipulation;\n        }\n\n        .control-btn:active {\n            transform: scale(0.95);\n            background-color: rgba(13, 71, 161, 0.9);\n        }\n\n        #fireBtn {\n            background-color: rgba(244, 67, 54, 0.9);\n            border-color: #ffcdd2;\n            box-shadow: 0 4px 15px rgba(244, 67, 54, 0.6);\n        }\n\n        #fireBtn:active {\n            background-color: rgba(198, 40, 40, 0.9);\n        }\n\n        /* 游戏菜单/开始屏幕 */\n        #startScreen, #gameOverScreen {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background-color: rgba(10, 14, 41, 0.95);\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            z-index: 100;\n            padding: 2rem;\n            text-align: center;\n        }\n\n        .title {\n            font-size: 3rem;\n            margin-bottom: 1.5rem;\n            background: linear-gradient(to right, #4fc3f7, #2979ff);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n            text-shadow: 0 0 20px rgba(79, 195, 247, 0.7);\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            margin-bottom: 3rem;\n            color: #bbdefb;\n            max-width: 320px;\n            line-height: 1.6;\n        }\n\n        .menu-btn {\n            background: linear-gradient(to bottom, #2979ff, #0d47a1);\n            color: white;\n            border: none;\n            padding: 1rem 2.5rem;\n            font-size: 1.3rem;\n            border-radius: 2rem;\n            margin: 0.8rem 0;\n            cursor: pointer;\n            min-width: 200px;\n            min-height: 60px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            box-shadow: 0 6px 20px rgba(41, 121, 255, 0.4);\n            transition: all 0.2s;\n            pointer-events: auto;\n            touch-action: manipulation;\n        }\n\n        .menu-btn:active {\n            transform: translateY(4px);\n            box-shadow: 0 2px 10px rgba(41, 121, 255, 0.4);\n        }\n\n        #gameOverScreen {\n            display: none;\n        }\n\n        .final-score {\n            font-size: 2.5rem;\n            color: #ffeb3b;\n            margin: 1.5rem 0;\n            text-shadow: 0 0 10px rgba(255, 235, 59, 0.7);\n        }\n\n        /* 触摸移动区域 */\n        #touchPad {\n            position: absolute;\n            bottom: 2rem;\n            left: 1.5rem;\n            width: calc(100% - 180px);\n            height: 150px;\n            /* background-color: rgba(255,255,255,0.05); */\n            pointer-events: auto;\n            touch-action: manipulation;\n            z-index: 5;\n        }\n\n        /* 动画 */\n        @media (prefers-reduced-motion: no-preference) {\n            .title {\n                animation: pulse 2s infinite alternate;\n            }\n\n            @keyframes pulse {\n                from { transform: scale(1); }\n                to { transform: scale(1.05); }\n            }\n\n            .control-btn {\n                transition: transform 0.1s, background-color 0.1s;\n            }\n\n            .menu-btn {\n                transition: transform 0.2s, box-shadow 0.2s;\n            }\n        }\n\n        /* 桌面端适配 */\n        @media (min-width: 768px) {\n            #gameContainer {\n                max-width: 768px;\n                margin: 0 auto;\n            }\n\n            .control-btn {\n                width: 80px;\n                height: 80px;\n                min-width: 80px;\n                min-height: 80px;\n                font-size: 2rem;\n            }\n\n            #touchPad {\n                width: calc(100% - 200px);\n                height: 180px;\n            }\n\n            .title {\n                font-size: 4rem;\n            }\n\n            .menu-btn {\n                min-width: 220px;\n                padding: 1.2rem 3rem;\n            }\n        }\n\n        /* 提示 */\n        .hint {\n            position: absolute;\n            bottom: 12rem;\n            width: 100%;\n            text-align: center;\n            color: #90caf9;\n            font-size: 0.9rem;\n            padding: 0 1rem;\n            pointer-events: none;\n        }\n\n        /* 确保竖屏 */\n        @media (orientation: landscape) and (max-height: 600px) {\n            .title {\n                font-size: 2rem;\n            }\n            .subtitle {\n                font-size: 1rem;\n                margin-bottom: 1.5rem;\n            }\n            .menu-btn {\n                padding: 0.8rem 1.5rem;\n                min-height: 50px;\n                margin: 0.5rem 0;\n            }\n            .hint {\n                bottom: 10rem;\n                font-size: 0.8rem;\n            }\n            .controls {\n                bottom: 1rem;\n            }\n            #touchPad {\n                height: 120px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div id=\"gameContainer\">\n        <canvas id=\"gameCanvas\"></canvas>\n        <div id=\"gameUI\">\n            <div class=\"status-bar\">\n                <div class=\"score\">得分: <span id=\"scoreValue\">0</span></div>\n                <div class=\"lives\">生命: <span id=\"livesValue\">3</span></div>\n                <div class=\"level\">关卡: <span id=\"levelValue\">1</span></div>\n            </div>\n            <div class=\"hint\" id=\"mobileHint\">移动手指控制战机，点击按钮开火！</div>\n            <div class=\"controls\">\n                <div class=\"control-btn\" id=\"leftBtn\">←</div>\n                <div class=\"control-btn\" id=\"fireBtn\">🔥</div>\n                <div class=\"control-btn\" id=\"rightBtn\">→</div>\n            </div>\n            <div id=\"touchPad\"></div>\n        </div>\n\n        <div id=\"startScreen\">\n            <h1 class=\"title\">雷霆战机</h1>\n            <p class=\"subtitle\">抵御外星入侵者！移动战机，发射激光，在无尽的太空中生存下去。</p>\n            <button class=\"menu-btn\" id=\"startBtn\">开始游戏</button>\n            <button class=\"menu-btn\" id=\"instructionsBtn\">游戏说明</button>\n        </div>\n\n        <div id=\"gameOverScreen\">\n            <h1 class=\"title\">游戏结束</h1>\n            <p class=\"subtitle\">你的英勇战斗被记录在了星辰之中。</p>\n            <div class=\"final-score\">最终得分: <span id=\"finalScore\">0</span></div>\n            <button class=\"menu-btn\" id=\"restartBtn\">再战一次</button>\n            <button class=\"menu-btn\" id=\"backToMenuBtn\">返回菜单</button>\n        </div>\n    </div>\n\n    <script>\n        (function() {\n            'use strict';\n\n            // 获取DOM元素\n            const canvas = document.getElementById('gameCanvas');\n            const ctx = canvas.getContext('2d');\n            const startScreen = document.getElementById('startScreen');\n            const gameOverScreen = document.getElementById('gameOverScreen');\n            const startBtn = document.getElementById('startBtn');\n            const restartBtn = document.getElementById('restartBtn');\n            const backToMenuBtn = document.getElementById('backToMenuBtn');\n            const instructionsBtn = document.getElementById('instructionsBtn');\n            const scoreValue = document.getElementById('scoreValue');\n            const livesValue = document.getElementById('livesValue');\n            const levelValue = document.getElementById('levelValue');\n            const finalScore = document.getElementById('finalScore');\n            const leftBtn = document.getElementById('leftBtn');\n            const rightBtn = document.getElementById('rightBtn');\n            const fireBtn = document.getElementById('fireBtn');\n            const touchPad = document.getElementById('touchPad');\n            const mobileHint = document.getElementById('mobileHint');\n\n            // 游戏变量\n            let gameRunning = false;\n            let score = 0;\n            let lives = 3;\n            let level = 1;\n            let lastTime = 0;\n            let enemySpawnTimer = 0;\n            let powerUpSpawnTimer = 0;\n            let isTouching = false;\n            let touchStartX = 0;\n            let player = null;\n            let bullets = [];\n            let enemies = [];\n            let powerUps = [];\n            let explosions = [];\n            let keys = {};\n\n            // 调整画布大小\n            function resizeCanvas() {\n                canvas.width = window.innerWidth;\n                canvas.height = window.innerHeight;\n            }\n            window.addEventListener('resize', resizeCanvas);\n            resizeCanvas();\n\n            // 游戏对象类\n            class GameObject {\n                constructor(x, y, width, height, color) {\n                    this.x = x;\n                    this.y = y;\n                    this.width = width;\n                    this.height = height;\n                    this.color = color;\n                    this.speedX = 0;\n                    this.speedY = 0;\n                }\n\n                draw() {\n                    ctx.fillStyle = this.color;\n                    ctx.fillRect(this.x - this.width/2, this.y - this.height/2, this.width, this.height);\n                }\n\n                update() {\n                    this.x += this.speedX;\n                    this.y += this.speedY;\n                }\n\n                collidesWith(other) {\n                    return this.x < other.x + other.width/2 &&\n                           this.x + this.width/2 > other.x &&\n                           this.y < other.y + other.height/2 &&\n                           this.y + this.height/2 > other.y;\n                }\n            }\n\n            class Player extends GameObject {\n                constructor() {\n                    super(canvas.width / 2, canvas.height - 80, 40, 60, '#4fc3f7');\n                    this.speed = 8;\n                    this.fireCooldown = 0;\n                    this.isInvincible = false;\n                    this.invincibleTimer = 0;\n                }\n\n                draw() {\n                    // 绘制玩家战机\n                    ctx.save();\n                    ctx.translate(this.x, this.y);\n\n                    // 机身\n                    ctx.fillStyle = this.isInvincible ? 'rgba(79, 195, 247, 0.5)' : this.color;\n                    ctx.beginPath();\n                    ctx.moveTo(0, -this.height/2);\n                    ctx.lineTo(-this.width/3, this.height/3);\n                    ctx.lineTo(-this.width/6, this.height/2);\n                    ctx.lineTo(this.width/6, this.height/2);\n                    ctx.lineTo(this.width/3, this.height/3);\n                    ctx.closePath();\n                    ctx.fill();\n\n                    // 驾驶舱\n                    ctx.fillStyle = '#e1f5fe';\n                    ctx.beginPath();\n                    ctx.arc(0, -this.height/6, this.width/5, 0, Math.PI * 2);\n                    ctx.fill();\n\n                    // 引擎光效\n                    if (gameRunning) {\n                        ctx.fillStyle = '#ff9800';\n                        ctx.beginPath();\n                        ctx.ellipse(-this.width/4, this.height/2 + 5, 4, 8, 0, 0, Math.PI * 2);\n                        ctx.ellipse(this.width/4, this.height/2 + 5, 4, 8, 0, 0, Math.PI * 2);\n                        ctx.fill();\n                    }\n\n                    ctx.restore();\n                }\n\n                update() {\n                    // 键盘控制\n                    if (keys['ArrowLeft'] || keys['a'] || keys['A']) {\n                        this.x -= this.speed;\n                    }\n                    if (keys['ArrowRight'] || keys['d'] || keys['D']) {\n                        this.x += this.speed;\n                    }\n\n                    // 触摸控制（通过 touchPad）\n                    // 边界限制\n                    this.x = Math.max(this.width/2, Math.min(canvas.width - this.width/2, this.x));\n                    this.y = Math.max(this.height/2, Math.min(canvas.height - this.height/2, this.y));\n\n                    // 开火冷却\n                    if (this.fireCooldown > 0) {\n                        this.fireCooldown--;\n                    }\n\n                    // 无敌时间\n                    if (this.isInvincible) {\n                        this.invincibleTimer--;\n                        if (this.invincibleTimer <= 0) {\n                            this.isInvincible = false;\n                        }\n                    }\n                }\n\n                fire() {\n                    if (this.fireCooldown === 0) {\n                        bullets.push(new Bullet(this.x, this.y - this.height/2, 0, -12, '#ffeb3b'));\n                        this.fireCooldown = 10; // 冷却时间\n                    }\n                }\n\n                takeDamage() {\n                    if (!this.isInvincible) {\n                        lives--;\n                        livesValue.textContent = lives;\n                        this.isInvincible = true;\n                        this.invincibleTimer = 120; // 2秒无敌时间（60fps）\n\n                        if (lives <= 0) {\n                            gameOver();\n                        }\n                    }\n                }\n            }\n\n            class Bullet extends GameObject {\n                constructor(x, y, speedX, speedY, color) {\n                    super(x, y, 6, 20, color);\n                    this.speedX = speedX;\n                    this.speedY = speedY;\n                }\n\n                draw() {\n                    ctx.fillStyle = this.color;\n                    ctx.beginPath();\n                    ctx.ellipse(this.x, this.y, this.width/2, this.height/2, 0, 0, Math.PI * 2);\n                    ctx.fill();\n\n                    // 光尾\n                    ctx.fillStyle = 'rgba(255, 255, 255, 0.7)';\n                    ctx.beginPath();\n                    ctx.ellipse(this.x, this.y + this.height/2 + 2, 2, 4, 0, 0, Math.PI * 2);\n                    ctx.fill();\n                }\n\n                update() {\n                    super.update();\n                    return this.y > -20 && this.y < canvas.height + 20 && this.x > -20 && this.x < canvas.width + 20;\n                }\n            }\n\n            class Enemy extends GameObject {\n                constructor(x, y, type) {\n                    let width, height, color, speedY, health;\n                    switch(type) {\n                        case 1: // 小型敌机\n                            width = 30; height = 30; color = '#f44336'; speedY = 2; health = 1; break;\n                        case 2: // 中型敌机\n                            width = 45; height = 45; color = '#ff9800'; speedY = 1.5; health = 2; break;\n                        default: // 大型敌机\n                            width = 60; height = 60; color = '#9c27b0'; speedY = 1; health = 3; break;\n                    }\n                    super(x, y, width, height, color);\n                    this.type = type;\n                    this.speedY = speedY;\n                    this.health = health;\n                    this.maxHealth = health;\n                }\n\n                draw() {\n                    // 绘制敌机\n                    ctx.save();\n                    ctx.translate(this.x, this.y);\n\n                    // 主体\n                    ctx.fillStyle = this.color;\n                    ctx.beginPath();\n                    if (this.type === 1) {\n                        // 三角形小型机\n                        ctx.moveTo(0, -this.height/2);\n                        ctx.lineTo(-this.width/2, this.height/2);\n                        ctx.lineTo(this.width/2, this.height/2);\n                    } else if (this.type === 2) {\n                        // 菱形中型机\n                        ctx.moveTo(0, -this.height/2);\n                        ctx.lineTo(-this.width/2, 0);\n                        ctx.lineTo(0, this.height/2);\n                        ctx.lineTo(this.width/2, 0);\n                    } else {\n                        // 六边形大型机\n                        ctx.moveTo(-this.width/3, -this.height/3);\n                        ctx.lineTo(-this.width/2, 0);\n                        ctx.lineTo(-this.width/3, this.height/3);\n                        ctx.lineTo(this.width/3, this.height/3);\n                        ctx.lineTo(this.width/2, 0);\n                        ctx.lineTo(this.width/3, -this.height/3);\n                    }\n                    ctx.closePath();\n                    ctx.fill();\n\n                    // 生命条\n                    if (this.maxHealth > 1) {\n                        const barWidth = this.width * 0.8;\n                        const barHeight = 4;\n                        const healthPercent = this.health / this.maxHealth;\n                        ctx.fillStyle = '#555';\n                        ctx.fillRect(-barWidth/2, -this.height/2 - 8, barWidth, barHeight);\n                        ctx.fillStyle = healthPercent > 0.5 ? '#4caf50' : (healthPercent > 0.25 ? '#ff9800' : '#f44336');\n                        ctx.fillRect(-barWidth/2, -this.height/2 - 8, barWidth * healthPercent, barHeight);\n                    }\n\n                    ctx.restore();\n                }\n\n                update() {\n                    this.y += this.speedY;\n                    // 轻微左右摆动\n                    this.x += Math.sin(this.y * 0.05) * 0.5;\n                    return this.y < canvas.height + 50;\n                }\n\n                takeDamage() {\n                    this.health--;\n                    return this.health <= 0;\n                }\n            }\n\n            class PowerUp extends GameObject {\n                constructor(x, y, type) {\n                    let width = 25, height = 25, color;\n                    switch(type) {\n                        case 'life': color = '#4caf50'; break;\n                        case 'score': color = '#ffeb3b'; break;\n                        default: color = '#2196f3'; break;\n                    }\n                    super(x, y, width, height, color);\n                    this.type = type;\n                    this.speedY = 2;\n                }\n\n                draw() {\n                    ctx.save();\n                    ctx.translate(this.x, this.y);\n\n                    // 旋转动画\n                    if (gameRunning) {\n                        ctx.rotate(Date.now() * 0.002);\n                    }\n\n                    // 绘制加成效能\n                    ctx.fillStyle = this.color;\n                    ctx.beginPath();\n                    if (this.type === 'life') {\n                        // 心形\n                        ctx.moveTo(0, -this.height/3);\n                        ctx.bezierCurveTo(-this.width/2, -this.height/2, -this.width/2, this.height/6, 0, this.height/2);\n                        ctx.bezierCurveTo(this.width/2, this.height/6, this.width/2, -this.height/2, 0, -this.height/3);\n                    } else if (this.type === 'score') {\n                        // 星形\n                        for (let i = 0; i < 5; i++) {\n                            const angle = i * Math.PI * 2 / 5;\n                            const spikeAngle = angle + Math.PI / 5;\n                            ctx.lineTo(Math.cos(angle) * this.width/2, Math.sin(angle) * this.height/2);\n                            ctx.lineTo(Math.cos(spikeAngle) * this.width/4, Math.sin(spikeAngle) * this.height/4);\n                        }\n                    } else {\n                        // 圆形\n                        ctx.arc(0, 0, this.width/2, 0, Math.PI * 2);\n                    }\n                    ctx.closePath();\n                    ctx.fill();\n\n                    ctx.restore();\n                }\n\n                update() {\n                    this.y += this.speedY;\n                    return this.y < canvas.height + 20;\n                }\n            }\n\n            class Explosion {\n                constructor(x, y, size) {\n                    this.x = x;\n                    this.y = y;\n                    this.size = size;\n                    this.life = 30;\n                    this.maxLife = 30;\n                }\n\n                draw() {\n                    const lifePercent = this.life / this.maxLife;\n                    const radius = this.size * (1 - lifePercent * 0.5);\n                    const alpha = lifePercent;\n\n                    ctx.save();\n                    ctx.globalAlpha = alpha;\n\n                    // 爆炸外层\n                    const gradient = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, radius);\n                    gradient.addColorStop(0, 'rgba(255, 255, 200, 0.9)');\n                    gradient.addColorStop(0.5, 'rgba(255, 150, 50, 0.7)');\n                    gradient.addColorStop(1, 'rgba(255, 50, 0, 0)');\n\n                    ctx.fillStyle = gradient;\n                    ctx.beginPath();\n                    ctx.arc(this.x, this.y, radius, 0, Math.PI * 2);\n                    ctx.fill();\n\n                    // 爆炸内层\n                    const innerRadius = radius * 0.5;\n                    const innerGradient = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, innerRadius);\n                    innerGradient.addColorStop(0, 'rgba(255, 255, 255, 1)');\n                    innerGradient.addColorStop(1, 'rgba(255, 200, 0, 0)');\n\n                    ctx.fillStyle = innerGradient;\n                    ctx.beginPath();\n                    ctx.arc(this.x, this.y, innerRadius, 0, Math.PI * 2);\n                    ctx.fill();\n\n                    ctx.restore();\n                }\n\n                update() {\n                    this.life--;\n                    return this.life > 0;\n                }\n            }\n\n            // 游戏函数\n            function initGame() {\n                score = 0;\n                lives = 3;\n                level = 1;\n                player = new Player();\n                bullets = [];\n                enemies = [];\n                powerUps = [];\n                explosions = [];\n\n                scoreValue.textContent = score;\n                livesValue.textContent = lives;\n                levelValue.textContent = level;\n\n                gameRunning = true;\n                startScreen.style.display = 'none';\n                gameOverScreen.style.display = 'none';\n                mobileHint.style.display = 'block';\n\n                // 隐藏说明提示\n                if (instructionsBtn.textContent === '返回游戏') {\n                    instructionsBtn.textContent = '游戏说明';\n                    mobileHint.style.display = 'block';\n                }\n            }\n\n            function gameOver() {\n                gameRunning = false;\n                finalScore.textContent = score;\n                gameOverScreen.style.display = 'flex';\n                mobileHint.style.display = 'none';\n            }\n\n            function spawnEnemy() {\n                const type = Math.random() < 0.6 ? 1 : (Math.random() < 0.8 ? 2 : 3);\n                const x = Math.random() * (canvas.width - 60) + 30;\n                enemies.push(new Enemy(x, -30, type));\n            }\n\n            function spawnPowerUp(x, y) {\n                const types = ['life', 'score', 'shield'];\n                const type = types[Math.floor(Math.random() * types.length)];\n                powerUps.push(new PowerUp(x, y, type));\n            }\n\n            function updateGame(deltaTime) {\n                if (!gameRunning) return;\n\n                // 更新玩家\n                player.update();\n\n                // 更新子弹\n                for (let i = bullets.length - 1; i >= 0; i--) {\n                    if (!bullets[i].update()) {\n                        bullets.splice(i, 1);\n                        continue;\n                    }\n\n                    // 子弹与敌机碰撞检测\n                    for (let j = enemies.length - 1; j >= 0; j--) {\n                        if (bullets[i].collidesWith(enemies[j])) {\n                            if (enemies[j].takeDamage()) {\n                                // 敌机被摧毁\n                                score += enemies[j].type * 100;\n                                scoreValue.textContent = score;\n                                explosions.push(new Explosion(enemies[j].x, enemies[j].y, enemies[j].width));\n\n                                // 随机掉落道具\n                                if (Math.random() < 0.2) {\n              