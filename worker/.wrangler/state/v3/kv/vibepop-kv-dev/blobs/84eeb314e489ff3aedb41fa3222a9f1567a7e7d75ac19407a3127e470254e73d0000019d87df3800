ions.length - 1; i >= 0; i--) {\n                    if (!explosions[i].update()) {\n                        explosions.splice(i, 1);\n                    }\n                }\n\n                // 敌机生成\n                enemySpawnTimer += deltaTime;\n                const spawnInterval = Math.max(500, 1000 - level * 100); // 随关卡加快\n                if (enemySpawnTimer > spawnInterval) {\n                    spawnEnemy();\n                    enemySpawnTimer = 0;\n                }\n\n                // 道具生成（自然生成）\n                powerUpSpawnTimer += deltaTime;\n                if (powerUpSpawnTimer > 10000) { // 每10秒\n                    if (Math.random() < 0.3) {\n                        const x = Math.random() * (canvas.width - 50) + 25;\n                        spawnPowerUp(x, -30);\n                    }\n                    powerUpSpawnTimer = 0;\n                }\n\n                // 关卡升级\n                if (score >= level * 5000) {\n                    level++;\n                    levelValue.textContent = level;\n                }\n            }\n\n            function drawGame() {\n                // 清空画布\n                ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n                // 绘制星空背景\n                drawStars();\n\n                // 绘制所有游戏对象\n                powerUps.forEach(p => p.draw());\n                bullets.forEach(b => b.draw());\n                enemies.forEach(e => e.draw());\n                explosions.forEach(e => e.draw());\n                player.draw();\n\n                // 绘制无敌闪烁效果\n                if (player.isInvincible && Math.floor(player.invincibleTimer / 5) % 2 === 0) {\n                    ctx.strokeStyle = 'rgba(255, 255, 255, 0.7)';\n                    ctx.lineWidth = 3;\n                    ctx.beginPath();\n                    ctx.arc(player.x, player.y, player.width/2 + 5, 0, Math.PI * 2);\n                    ctx.stroke();\n                }\n            }\n\n            function drawStars() {\n                // 简单的静态星空\n                if (!window.stars) {\n                    window.stars = [];\n                    for (let i = 0; i < 100; i++) {\n                        window.stars.push({\n                            x: Math.random() * canvas.width,\n                            y: Math.random() * canvas.height,\n                            size: Math.random() * 1.5 + 0.5,\n                            brightness: Math.random() * 0.5 + 0.5\n                        });\n                    }\n                }\n\n                window.stars.forEach(star => {\n                    ctx.fillStyle = `rgba(255, 255, 255, ${star.brightness})`;\n                    ctx.beginPath();\n                    ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);\n                    ctx.fill();\n                });\n            }\n\n            function gameLoop(timestamp) {\n                const deltaTime = timestamp - lastTime || 0;\n                lastTime = timestamp;\n\n                updateGame(deltaTime);\n                drawGame();\n\n                requestAnimationFrame(gameLoop);\n            }\n\n            // 事件监听\n            startBtn.addEventListener('click', initGame);\n            restartBtn.addEventListener('click', initGame);\n\n            backToMenuBtn.addEventListener('click', () => {\n                gameOverScreen.style.display = 'none';\n                startScreen.style.display = 'flex';\n            });\n\n            instructionsBtn.addEventListener('click', () => {\n                if (instructionsBtn.textContent === '游戏说明') {\n                    instructionsBtn.textContent = '返回游戏';\n                    mobileHint.style.display = 'none';\n                    alert('游戏说明：\\n1. 使用左右箭头键或屏幕按钮控制战机移动\\n2. 点击开火按钮或空格键发射子弹\\n3. 摧毁敌机获得分数\\n4. 收集绿色心形恢复生命，黄色星形获得额外分数\\n5. 避免与敌机碰撞\\n6. 每5000分提升一个关卡，敌机速度加快');\n                } else {\n                    instructionsBtn.textContent = '游戏说明';\n                    if (gameRunning) {\n                        mobileHint.style.display = 'block';\n                    }\n                }\n            });\n\n            // 键盘控制\n            window.addEventListener('keydown', (e) => {\n                keys[e.key] = true;\n                if (e.key === ' ' || e.key === 'Spacebar') {\n                    e.preventDefault();\n                    if (gameRunning) player.fire();\n                }\n            });\n\n            window.addEventListener('keyup', (e) => {\n                keys[e.key] = false;\n            });\n\n            // 按钮控制\n            leftBtn.addEventListener('mousedown', () => keys['ArrowLeft'] = true);\n            leftBtn.addEventListener('mouseup', () => keys['ArrowLeft'] = false);\n            leftBtn.addEventListener('touchstart', (e) => {\n                e.preventDefault();\n                keys['ArrowLeft'] = true;\n            });\n            leftBtn.addEventListener('touchend', (e) => {\n                e.preventDefault();\n                keys['ArrowLeft'] = false;\n            });\n\n            rightBtn.addEventListener('mousedown', () => keys['ArrowRight'] = true);\n            rightBtn.addEventListener('mouseup', () => keys['ArrowRight'] = false);\n            rightBtn.addEventListener('touchstart', (e) => {\n                e.preventDefault();\n                keys['ArrowRight'] = true;\n            });\n            rightBtn.addEventListener('touchend', (e) => {\n                e.preventDefault();\n                keys['ArrowRight'] = false;\n            });\n\n            fireBtn.addEventListener('click', () => {\n                if (gameRunning) player.fire();\n            });\n            fireBtn.addEventListener('touchstart', (e) => {\n                e.preventDefault();\n                if (gameRunning) player.fire();\n            });\n\n            // 触摸板控制\n            touchPad.addEventListener('touchstart', (e) => {\n                e.preventDefault();\n                isTouching = true;\n                const touch = e.touches[0];\n                touchStartX = touch.clientX;\n                mobileHint.style.display = 'none'; // 隐藏提示\n            });\n\n            touchPad.addEventListener('touchmove', (e) => {\n                if (!isTouching || !gameRunning) return;\n                e.preventDefault();\n                const touch = e.touches[0];\n                const deltaX = touch.clientX - touchStartX;\n                const sensitivity = 0.5;\n                player.x += deltaX * sensitivity;\n                touchStartX = touch.clientX;\n            });\n\n            touchPad.addEventListener('touchend', (e) => {\n                e.preventDefault();\n                isTouching = false;\n            });\n\n            // 鼠标在触摸板上控制（桌面端测试用）\n            touchPad.addEventListener('mousedown', (e) => {\n                isTouching = true;\n                touchStartX = e.clientX;\n                mobileHint.style.display = 'none';\n            });\n\n            window.addEventListener('mousemove', (e) => {\n                if (!isTouching || !gameRunning) return;\n                const deltaX = e.clientX - touchStartX;\n                const sensitivity = 0.5;\n                player.x += deltaX * sensitivity;\n                touchStartX = e.clientX;\n            });\n\n            window.addEventListener('mouseup', () => {\n                isTouching = false;\n            });\n\n            // 防止上下文菜单\n            canvas.addEventListener('contextmenu', (e) => e.preventDefault());\n\n            // 启动游戏循环\n            requestAnimationFrame(gameLoop);\n        })();\n    </script>\n</body>\n</html>","coverUrl":"","coverEmoji":"🎮","coverGradient":"linear-gradient(135deg, #fa709a 0%, #fee140 100%)","tags":[],"authorId":"u_b6cdb943","status":"published","playCount":0,"likeCount":0,"favoriteCount":0,"commentCount":0,"remixCount":0,"createdAt":"2026-04-13T17:24:06.271Z","publishedAt":"2026-04-13T17:24:06.271Z"}